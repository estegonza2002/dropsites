{
  "name": "@dropsites/mcp",
  "version": "1.0.0",
  "description": "MCP server for DropSites — deploy static sites from Claude Desktop and claude.ai",
  "type": "module",
  "bin": {
    "dropsites-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@dropsites/sdk": "workspace:*",
    "archiver": "^7.0.1",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^20",
    "typescript": "^5.4.0"
  },
  "keywords": ["dropsites", "mcp", "claude", "static-hosting", "deploy", "model-context-protocol"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dropsites/dropsites"
  },
  "homepage": "https://dropsites.app/mcp",
  "engines": { "node": ">=18.0.0" }
}
